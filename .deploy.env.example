# Copy to .deploy.env (gitignored) and set your hosting password.
# SFTP_PASSWORD is used by scripts/deploy-sftp.py — never commit .deploy.env
#
# IONOS: Hosting → your package → SFTP & SSH → connection data
# Account type must be "SFTP + SSH" if you want shell access (optional).

SFTP_HOST=home387541923.1and1-data.host
SFTP_PORT=22
SFTP_USER=u66236303
SFTP_REMOTE_PATH=/

# Required on IONOS shared hosting until key auth is enabled
SFTP_PASSWORD=your-hosting-password
