{
  "name": "mike-p.co.uk",
  "host": "your-sftp-host.example.com",
  "protocol": "sftp",
  "port": 22,
  "username": "your-sftp-username",
  "password": "SET_IN_GENERATED_sftp.json",
  "remotePath": "/",
  "uploadOnSave": true,
  "useTempFile": false,
  "openSsh": false,
  "ignore": [
    ".vscode",
    ".cursor",
    ".git",
    "node_modules",
    "scripts",
    ".deploy.env",
    ".deploy.env.example",
    "package.json",
    "package-lock.json",
    "playwright.config.js",
    ".DS_Store",
    ".php-cs-fixer.cache",
    "*.code-workspace",
    "*.sh",
    "*.command"
  ]
}
